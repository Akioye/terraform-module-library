# Local .terraform directories
**/.terraform/*

# Terraform lock files (commit these — they pin provider versions)
# .terraform.lock.hcl  ← do NOT ignore this

# State files — never commit state to git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files — never commit secrets
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files (used for local testing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated by Terraform
.terraform.tfstate.lock.info

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Plan output files (contain sensitive data)
*.tfplan
*.plan
